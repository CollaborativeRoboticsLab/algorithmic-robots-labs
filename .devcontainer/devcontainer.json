{
    "name": "Algorithmic Robots Jupyter",
    "dockerFile": "../Dockerfile",
    "remoteUser": "jovyan",
    "context": "..",
    "runArgs": [
        "--privileged",
        "--network=host"
    ],
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/jovyan/work,type=bind",
    "workspaceFolder": "/home/jovyan/work",
    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.bash_history,target=/home/jovyan/.bash_history,type=bind"
    ]
}